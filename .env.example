# DomainRecon - Environment Variables
# Copy this file to .env and adjust the values.

# Application
HOST=0.0.0.0
PORT=9000
ENV=development

# PostgreSQL (used with Docker, optional)
# If not set, the app defaults to SQLite (zero config).
POSTGRES_USER=domainrecon_user
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=domainrecon_db
# DATABASE_URL=postgresql://domainrecon_user:changeme@localhost:5432/domainrecon_db
